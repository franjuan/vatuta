# Automatically load environment variables from .env file
dotenv

# Load Poetry virtual environment
# Get Poetry virtual environment path and activate it
if command -v poetry >/dev/null 2>&1; then
    VENV_PATH=$(poetry env info --path 2>/dev/null || true)
    if [ -n "$VENV_PATH" ]; then
        export VIRTUAL_ENV="$VENV_PATH"
        export PATH="$VIRTUAL_ENV/bin:$PATH"
        echo "Poetry virtual environment activated: $VIRTUAL_ENV"
    else
        echo "Poetry virtual environment not found. Run 'just install' to create it."
    fi
else
    echo "Poetry not found. Please install Poetry first."
fi
