# Environment configuration example
# Copy this file to .env and fill in your values.
#
# Note: most source configuration (URLs, projects, spaces, channels) lives in
# config/vatuta.yaml. Only credentials and global settings belong here.

# ──────────────────────────────────────────────────────────
# LLM Backends
# ──────────────────────────────────────────────────────────

# Google Gemini
GEMINI_API_KEY=your_gemini_api_key

# AWS Bedrock — use EITHER bearer token OR an AWS profile (not both)
AWS_REGION=us-east-1
AWS_PROFILE=your_aws_profile_name
# AWS_BEARER_TOKEN_BEDROCK=your_bearer_token   # alternative to profile auth
# See: https://docs.aws.amazon.com/bedrock/latest/userguide/api-keys-use.html

# ──────────────────────────────────────────────────────────
# Data Sources — credentials only
# URLs, projects and spaces are configured in config/vatuta.yaml
# ──────────────────────────────────────────────────────────

# Jira & Confluence (share the same Atlassian credentials)
JIRA_USER=your_jira_email@company.com
JIRA_API_TOKEN=your_jira_api_token_here

# Slack
SLACK_BOT_TOKEN=xoxb-your_bot_token

# ──────────────────────────────────────────────────────────
# Infrastructure
# ──────────────────────────────────────────────────────────

# Qdrant — leave empty for unauthenticated local dev
QDRANT_API_KEY=

# ──────────────────────────────────────────────────────────
# Application
# ──────────────────────────────────────────────────────────

LOG_LEVEL=INFO
